					"database": "[parameters('P_server_details_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('P_server_details_properties_typeProperties_userName')]",
